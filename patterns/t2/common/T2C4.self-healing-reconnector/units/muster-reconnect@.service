[Unit]
Description=Muster bounded reconnector for %i
Documentation=file:README.md
OnFailure=muster-recover@%n.service

[Service]
Type=oneshot
User=muster
Group=muster
EnvironmentFile=-/etc/muster/reconnector.env
ExecStart=/usr/local/lib/muster/reconnect.sh %i --apply
RuntimeDirectory=muster
StateDirectory=muster/reconnector
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/run/muster /var/lib/muster
