[Unit]
Description=Muster socket anteroom responder
Documentation=file:README.md

[Service]
Type=simple
User=muster
Group=muster
EnvironmentFile=-/etc/muster/socket-anteroom.env
ExecStart=/usr/local/lib/muster/socket-anteroom-serve.sh --apply
StandardInput=socket
StandardOutput=socket
RuntimeDirectory=muster
StateDirectory=muster/socket-anteroom
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/run/muster /var/lib/muster/socket-anteroom
