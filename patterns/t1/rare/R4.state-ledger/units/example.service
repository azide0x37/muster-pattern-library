[Unit]
Description=Muster state ledger writer example
Documentation=file:README.md

[Service]
Type=oneshot
User=muster
Group=muster
EnvironmentFile=-/etc/muster/state-ledger.env
ExecStart=/usr/local/lib/muster/state-ledger-write.sh --apply
RuntimeDirectory=muster
StateDirectory=muster/state-ledger
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/run/muster /var/lib/muster/state-ledger
