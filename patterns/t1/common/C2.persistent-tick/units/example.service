[Unit]
Description=Muster persistent tick job
Documentation=file:README.md
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=muster
Group=muster
EnvironmentFile=-/etc/muster/persistent-tick.env
ExecStart=/usr/local/lib/muster/persistent-tick-run.sh --apply
RuntimeDirectory=muster
StateDirectory=muster/persistent-tick
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/run/muster /var/lib/muster
