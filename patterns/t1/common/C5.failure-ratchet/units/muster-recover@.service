[Unit]
Description=Muster recovery handler for %i
Documentation=file:README.md

[Service]
Type=oneshot
User=muster
Group=muster
Environment=RECOVERY_SUBJECT=%i
ExecStart=/usr/local/lib/muster/muster-recover.sh %i --apply
RuntimeDirectory=muster
StateDirectory=muster/recovery
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/run/muster /var/lib/muster
