[Unit]
Description=Muster dropfolder trigger processor
Documentation=file:README.md
After=local-fs.target

[Service]
Type=oneshot
User=muster
Group=muster
EnvironmentFile=-/etc/muster/dropfolder-trigger.env
ExecStart=/usr/local/lib/muster/dropfolder-process.sh --once --apply
RuntimeDirectory=muster
StateDirectory=muster/dropfolder
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/run/muster /var/lib/muster/dropfolder
