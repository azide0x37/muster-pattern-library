[Unit]
Description=Muster holonomy detector loop check example
Documentation=file:README.md

[Service]
Type=oneshot
User=muster
Group=muster
EnvironmentFile=-/etc/muster/holonomy-detector.env
ExecStart=/usr/local/lib/muster/holonomy-check.sh --apply
RuntimeDirectory=muster
StateDirectory=muster/holonomy
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/run/muster /var/lib/muster/holonomy
