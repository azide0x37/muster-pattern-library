[Unit]
Description=Muster local topos runtime evaluator example
Documentation=file:README.md

[Service]
Type=oneshot
User=muster
Group=muster
EnvironmentFile=-/etc/muster/local-topos-runtime.env
ExecStart=/usr/local/lib/muster/topos-evaluate.sh --apply
RuntimeDirectory=muster
StateDirectory=muster/topos
NoNewPrivileges=true
PrivateTmp=true
ProtectHome=true
ProtectSystem=strict
ReadWritePaths=/run/muster /var/lib/muster/topos
