{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/muster/pattern.schema.json",
  "title": "Muster Pattern Manifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "tech_level",
    "rarity",
    "mrl",
    "summary",
    "provides",
    "requires",
    "subpatterns",
    "composes_with",
    "artifacts",
    "status"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(C|R|M|T2C|T2R|T2M|T3C|T3R|T3M)[0-9]+\\.[a-z0-9]+(?:-[a-z0-9]+)*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "tech_level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 3
    },
    "rarity": {
      "type": "string",
      "enum": ["common", "rare", "mythic"]
    },
    "mrl": {
      "type": "integer",
      "minimum": 1,
      "maximum": 9
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "provides": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "requires": {
      "type": "array",
      "items": { "type": "string" }
    },
    "subpatterns": {
      "type": "array",
      "items": { "type": "string" }
    },
    "composes_with": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "lifecycle": {
      "type": "object",
      "required": ["managed", "install_modes", "doctor_modes", "rollback", "uninstall", "update"],
      "properties": {
        "managed": {
          "type": "boolean"
        },
        "install_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["dry_run", "staged_root", "apply"]
          },
          "minItems": 1
        },
        "doctor_modes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["local", "mock", "staged_root"]
          },
          "minItems": 1
        },
        "rollback": {
          "type": "string",
          "enum": ["documented", "artifact_generation", "doctor_gated"]
        },
        "uninstall": {
          "type": "string",
          "enum": ["documented", "artifacts_only"]
        },
        "update": {
          "type": "string",
          "enum": ["none", "manifest_sha256", "signed_manifest"]
        }
      },
      "additionalProperties": false
    },
    "status": {
      "type": "object",
      "required": ["implementation", "docs", "tests"],
      "properties": {
        "implementation": {
          "type": "string",
          "enum": ["concept", "draft", "usable", "stable"]
        },
        "docs": {
          "type": "string",
          "enum": ["draft", "reviewed", "stable"]
        },
        "tests": {
          "type": "string",
          "enum": ["missing", "draft", "reviewed", "stable"]
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
